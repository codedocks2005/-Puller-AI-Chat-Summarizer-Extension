{
  "manifest_version": 3,
  "name": "puller",
  "version": "1.3.0",
  "description": "Summarize any AI chat — ChatGPT, Claude, Gemini, and more.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Puller — AI Chat Summarizer"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
